# Nova backend URL (HTTP) — used by Next.js rewrites to proxy /api/* calls
# Local: http://localhost:8765
# Production: https://nova-backend-bmsm.onrender.com
NOVA_BACKEND_URL=http://localhost:8765

# Nova backend WebSocket URL — used by the browser directly
# Local: ws://localhost:8765/ws
# Production: wss://nova-backend-bmsm.onrender.com/ws
NEXT_PUBLIC_WS_URL=ws://localhost:8765/ws
