# Path to Vibe-Budgeting SQLite (auto-detected if in default location)
# BUDGET_DB_PATH=C:/Users/pacat/projects/claude/Vibe-Budgeting/database.db

# TTS voice (run: edge-tts --list-voices)
# Ελληνικές φωνές: el-GR-NestorasNeural (ανδρική) | el-GR-AthinaNeural (γυναικεία)
# Αγγλικές φωνές: en-GB-RyanNeural | en-US-GuyNeural
TTS_VOICE=el-GR-NestorasNeural

# Whisper model: tiny / base / small (tiny = fastest, base = better accuracy)
WHISPER_MODEL=base

# ── Telegram bot (Phase 3) ────────────────────────────────────────────────────
# Get a token from @BotFather on Telegram
# JARVIS_BOT_TOKEN=123456:ABC-DEF...

# Optional: restrict to specific Telegram chat IDs (comma-separated)
# Find your chat ID by messaging @userinfobot
# Leave empty to allow any chat (not recommended)
# JARVIS_ALLOWED_CHAT_IDS=123456789,987654321

# ── Apple Calendar via iCloud ─────────────────────────────────────────────────
# Generate app-specific passwords at: https://appleid.apple.com
# → Sign-In and Security → App-Specific Passwords → Generate (one per user)

# Your account
# OWNER_APPLE_ID=your@icloud.com
# OWNER_APPLE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Andriana's account
# ANDRIANA_APPLE_ID=andriana@icloud.com
# ANDRIANA_APPLE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# ANDRIANA_BUDGET_DB_PATH=C:/Users/pacat/projects/claude/andriana-budget.db

# Name of your shared Apple Calendar (as it appears in Apple Calendar)
# SHARED_CALENDAR_NAME=Together

# ── Claude Haiku fallback (Phase 3) ──────────────────────────────────────────
# Used ONLY for intents that the local regex can't classify (~10-20% of commands)
# Get key from https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...
