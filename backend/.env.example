# ── Claude API (required — Nova's brain) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Voice pipeline ────────────────────────────────────────────────────────────
# TTS voice (run: edge-tts --list-voices)
# Greek: el-GR-NestorasNeural (male) | el-GR-AthinaNeural (female)
TTS_VOICE=el-GR-NestorasNeural

# Whisper model: tiny / base / small (tiny = fastest, base = better accuracy)
WHISPER_MODEL=base

# ── Groq (optional — only for local Whisper STT fallback) ────────────────────
# GROQ_API_KEY=gsk_...

# ── Telegram bot ──────────────────────────────────────────────────────────────
# NOVA_BOT_TOKEN=123456:ABC-DEF...
# NOVA_ALLOWED_CHAT_IDS=123456789,987654321

# ── Apple Calendar via iCloud ─────────────────────────────────────────────────
# Generate app-specific passwords at: https://appleid.apple.com
# → Sign-In and Security → App-Specific Passwords → Generate

# OWNER_APPLE_ID=your@icloud.com
# OWNER_APPLE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ANDRIANA_APPLE_ID=andriana@icloud.com
# ANDRIANA_APPLE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# ANDRIANA_BUDGET_DB_PATH=/path/to/andriana-budget.db

# Name of your shared Apple Calendar
# SHARED_CALENDAR_NAME=Together

# ── Budget DB (local SQLite — temporary until Budget app is deployed) ─────────
# BUDGET_DB_PATH=/path/to/Vibe-Budgeting/database.db

# ── Timezone ──────────────────────────────────────────────────────────────────
# TIMEZONE=Europe/Athens
